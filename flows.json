    {
        "id": "json-parse-buttons",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Parse Buttons",
        "func": "try {\n    let payload = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload;\n    msg.payload = {\n        measurement: \"buttons\",\n        tags: {type: \"digital\"},\n        fields: {btn1: payload.btn1, btn2: payload.btn2},\n        timestamp: Date.now()\n    };\n    return msg;\n} catch (e) {\n    node.warn(\"Buttons parse error: \" + e);\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
