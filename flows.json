            ["json-parse-joystick"]
        ]
    },
    {
        "id": "json-parse-joystick",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Parse Joystick",
        "func": "try {\n    let payload = typeof msg.payload === 'string' ? JSON.parse(msg.payload) : msg.payload;\n    msg.payload = {\n        measurement: \"joystick\",\n        tags: {type: \"analog\"},\n        fields: {x: payload.x, y: payload.y},\n        timestamp: Date.now()\n    };\n    return msg;\n} catch (e) {\n    node.warn(\"Joystick parse error: \" + e);\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 350,
        "y": 140,
        "wires": [
            ["influx-write"]
        ]
    },
